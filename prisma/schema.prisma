generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  passwordHash     String
  name             String
  role             Role              @default(Client)
  isActive         Boolean           @default(true)
  clientId         String?
  organisationId   String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?
  client           Client?           @relation(fields: [clientId], references: [id])
  organisation     Organisation?     @relation(fields: [organisationId], references: [id])
  advisedCases     PermitCase[]      @relation("PermitAdvisor")
  checkedItems     PermitChecklist[] @relation("PermitChecker")
  updatedDeadlines TaxDeadline[]     @relation("DeadlineUpdater")

  @@map("users")
}

model Organisation {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
  clients   Client[]

  @@map("organisations")
}

model Client {
  id                 String                    @id @default(cuid())
  nama               String
  npwp               String
  jenisWP            JenisWP
  email              String
  telepon            String
  alamat             String
  status             ClientStatus
  organisationId     String?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  deletedAt          DateTime?
  organisation       Organisation?             @relation(fields: [organisationId], references: [id])
  users              User[]
  accountingDocs     AccountingDocument[]
  accounts           Account[]
  documents          Document[]
  financialSnapshots FinancialReportSnapshot[]
  fixedAssets        FixedAsset[]
  importBatches      ImportBatch[]
  invoices           Invoice[]
  journals           JournalEntry[]
  permits            PermitCase[]
  recurring          RecurringInvoice[]
  deadlines          TaxDeadline[]
  fiscalPeriodCloses FiscalPeriodClose[]

  @@map("clients")
}

model TaxDeadline {
  id            String            @id @default(cuid())
  jenisPajak    String
  deskripsi     String
  tanggalBatas  DateTime
  masaPajak     String
  status        TaxDeadlineStatus
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  deletedAt     DateTime?
  reportedAt    DateTime?
  updatedBy     String?
  clientId      String
  documents     Document[]
  client        Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  updatedByUser User?             @relation("DeadlineUpdater", fields: [updatedBy], references: [id])

  @@index([clientId, status])
  @@map("tax_deadlines")
}

model Document {
  id            String           @id @default(cuid())
  nama          String
  kategori      DocumentKategori
  ukuran        Int
  tanggalUpload DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  deletedAt     DateTime?
  catatan       String?
  fileUrl       String?
  clientId      String
  permitCaseId  String?
  invoiceId     String?
  deadlineId    String?
  client        Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  deadline      TaxDeadline?     @relation(fields: [deadlineId], references: [id], onDelete: Cascade)
  invoice       Invoice?         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  permitCase    PermitCase?      @relation("PermitCaseToDocument", fields: [permitCaseId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("documents")
}

model Invoice {
  id                 String            @id @default(cuid())
  nomorInvoice       String            @unique
  tanggal            DateTime          @default(now())
  jatuhTempo         DateTime
  subtotal           Float
  ppn                Float
  total              Float
  status             InvoiceStatus
  catatan            String?
  createdBy          String?
  updatedByUser      String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  deletedAt          DateTime?
  recurringInvoiceId String?
  clientId           String
  clientName         String
  clientNpwp         String?
  clientAlamat       String?
  documents          Document[]
  items              InvoiceItem[]
  client             Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  recurringInvoice   RecurringInvoice? @relation(fields: [recurringInvoiceId], references: [id])
  payments           Payment[]

  @@index([clientId, status])
  @@map("invoices")
}

model InvoiceItem {
  id        String   @id @default(cuid())
  deskripsi String
  qty       Int
  harga     Float
  jumlah    Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_items")
}

model Payment {
  id               String    @id @default(cuid())
  invoiceId        String
  jumlah           Float
  tanggalBayar     DateTime  @default(now())
  metodePembayaran String?
  buktiUrl         String?
  catatan          String?
  createdBy        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?
  invoice          Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("payments")
}

model RecurringInvoice {
  id          String                 @id @default(cuid())
  interval    RecurringInterval
  nextRunDate DateTime
  isActive    Boolean                @default(true)
  catatan     String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  deletedAt   DateTime?
  clientId    String
  invoices    Invoice[]
  items       RecurringInvoiceItem[]
  client      Client                 @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("recurring_invoices")
}

model RecurringInvoiceItem {
  id                 String           @id @default(cuid())
  deskripsi          String
  qty                Int
  harga              Float
  jumlah             Float
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  recurringInvoiceId String
  recurringInvoice   RecurringInvoice @relation(fields: [recurringInvoiceId], references: [id], onDelete: Cascade)

  @@index([recurringInvoiceId])
  @@map("recurring_invoice_items")
}

model PermitType {
  id             String                @id @default(cuid())
  slug           String                @unique
  name           String
  caseIdPrefix   String
  description    String?
  icon           String?
  cases          PermitCase[]
  checklistItems PermitTypeChecklist[]
  requiredDocs   PermitTypeDocument[]

  @@map("permit_types")
}

model PermitTypeDocument {
  id           String     @id @default(cuid())
  permitTypeId String
  docType      String
  isRequired   Boolean    @default(true)
  sortOrder    Int        @default(0)
  permitType   PermitType @relation(fields: [permitTypeId], references: [id], onDelete: Cascade)

  @@map("permit_type_documents")
}

model PermitTypeChecklist {
  id           String     @id @default(cuid())
  permitTypeId String
  label        String
  description  String?
  sortOrder    Int        @default(0)
  permitType   PermitType @relation(fields: [permitTypeId], references: [id], onDelete: Cascade)

  @@map("permit_type_checklists")
}

model PermitCounter {
  id      String @id
  counter Int    @default(0)

  @@map("permit_counters")
}

model PermitCase {
  id              String            @id @default(cuid())
  caseId          String            @unique
  permitTypeId    String
  clientId        String
  advisorId       String?
  serviceType     String
  riskCategory    String
  status          PermitCaseStatus
  priority        PermitPriority    @default(Medium)
  feeAmount       Float
  notes           String?
  applicationData Json?
  deadline        DateTime?
  cancelReason    String?
  completedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?
  attachedDocs    Document[]        @relation("PermitCaseToDocument")
  advisor         User?             @relation("PermitAdvisor", fields: [advisorId], references: [id])
  client          Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  permitType      PermitType        @relation(fields: [permitTypeId], references: [id])
  activities      PermitActivity[]
  checklists      PermitChecklist[]
  comments        PermitComment[]
  deadlines       PermitDeadline[]
  documents       PermitDocument[]

  @@index([clientId, status])
  @@index([permitTypeId])
  @@map("permit_cases")
}

model PermitDocument {
  id                 String             @id @default(cuid())
  caseId             String
  docType            String
  fileUrl            String?
  verificationStatus VerificationStatus
  comments           String?
  sortOrder          Int                @default(0)
  fileSize           Int?
  fileType           String?
  version            Int                @default(1)
  uploadedBy         String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  permitCase         PermitCase         @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@map("permit_documents")
}

model PermitChecklist {
  id            String     @id @default(cuid())
  caseId        String
  label         String
  description   String?
  isChecked     Boolean    @default(false)
  checkedAt     DateTime?
  checkedBy     String?
  sortOrder     Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  permitCase    PermitCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  checkedByUser User?      @relation("PermitChecker", fields: [checkedBy], references: [id])

  @@index([caseId])
  @@map("permit_checklists")
}

model PermitActivity {
  id          String     @id @default(cuid())
  caseId      String
  action      String
  description String
  metadata    Json?
  performedBy String?
  createdAt   DateTime   @default(now())
  permitCase  PermitCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId, createdAt])
  @@map("permit_activities")
}

model PermitComment {
  id         String          @id @default(cuid())
  caseId     String
  userId     String
  userName   String
  userRole   String
  message    String
  parentId   String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  permitCase PermitCase      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  parent     PermitComment?  @relation("CommentThread", fields: [parentId], references: [id])
  replies    PermitComment[] @relation("CommentThread")

  @@index([caseId, createdAt])
  @@map("permit_comments")
}

model PermitDeadline {
  id          String     @id @default(cuid())
  caseId      String
  label       String
  dueDate     DateTime
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  permitCase  PermitCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@map("permit_deadlines")
}

model Account {
  id           String        @id @default(cuid())
  code         String
  name         String
  type         AccountType
  isActive     Boolean       @default(true)
  clientId     String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  client       Client?       @relation(fields: [clientId], references: [id])
  journalItems JournalItem[]

  @@unique([code, clientId])
  @@map("accounts")
}

model JournalEntry {
  id             String        @id @default(cuid())
  refNumber      String        @unique
  date           DateTime      @default(now())
  description    String?
  status         JournalStatus @default(Draft)
  clientId       String
  totalDebit     Decimal       @default(0) @db.Decimal(18, 2)
  totalCredit    Decimal       @default(0) @db.Decimal(18, 2)
  createdBy      String?
  updatedByUser  String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?
  importBatchId  String?
  source         String?
  relatedEntryId String?
  client         Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  importBatch    ImportBatch?  @relation(fields: [importBatchId], references: [id])
  relatedEntry   JournalEntry? @relation("JournalReversal", fields: [relatedEntryId], references: [id])
  reversals      JournalEntry[] @relation("JournalReversal")
  items          JournalItem[]
  fiscalClose    FiscalPeriodClose?

  @@index([clientId, status])
  @@index([clientId, date])
  @@index([clientId, source, date])
  @@map("journal_entries")
}

model JournalItem {
  id             String       @id @default(cuid())
  journalEntryId String
  accountId      String
  debit          Decimal      @default(0) @db.Decimal(18, 2)
  credit         Decimal      @default(0) @db.Decimal(18, 2)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  account        Account      @relation(fields: [accountId], references: [id])
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  @@index([journalEntryId])
  @@index([accountId])
  @@index([accountId, journalEntryId])
  @@map("journal_items")
}

model FiscalPeriodClose {
  id             String       @id @default(cuid())
  clientId       String
  periodLabel    String
  periodStart    DateTime
  periodEnd      DateTime
  closedAt       DateTime     @default(now())
  closedBy       String
  journalEntryId String       @unique
  netIncome      Decimal      @db.Decimal(18, 2)
  createdAt      DateTime     @default(now())
  client         Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id])

  @@unique([clientId, periodLabel])
  @@map("fiscal_period_closes")
}

model AccountingDocument {
  id           String        @id @default(cuid())
  documentName String
  documentType AccDocType
  linkedModule AccDocModule?
  documentDate DateTime
  description  String?
  fileUrl      String
  fileType     String
  fileSize     Int
  uploadedBy   String
  clientId     String
  ocrStatus    String?
  ocrData      Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, documentType])
  @@index([clientId, linkedModule])
  @@map("accounting_documents")
}

model ImportBatch {
  id           String         @id @default(cuid())
  fileName     String
  documentType String
  period       String?
  companyName  String?
  status       String         @default("COMPLETED")
  entriesCount Int            @default(0)
  skippedCount Int            @default(0)
  errorsCount  Int            @default(0)
  warnings     Json?
  importedBy   String
  completedAt  DateTime?
  clientId     String
  createdAt    DateTime       @default(now())
  deletedAt    DateTime?
  fixedAssets  FixedAsset[]
  client       Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  entries      JournalEntry[]

  @@index([clientId, createdAt])
  @@map("import_batches")
}

model FixedAsset {
  id                 String      @id @default(cuid())
  clientId           String
  importBatchId      String
  source             String
  name               String
  acquisitionDate    DateTime?
  quantity           Int         @default(1)
  depreciationRate   Decimal     @default(0) @db.Decimal(8, 4)
  costPrev           Decimal     @default(0) @db.Decimal(18, 2)
  mutasiIn           Decimal     @default(0) @db.Decimal(18, 2)
  mutasiOut          Decimal     @default(0) @db.Decimal(18, 2)
  costCurrent        Decimal     @default(0) @db.Decimal(18, 2)
  accumDeprecPrev    Decimal     @default(0) @db.Decimal(18, 2)
  deprecCurrentIn    Decimal     @default(0) @db.Decimal(18, 2)
  deprecCurrentOut   Decimal     @default(0) @db.Decimal(18, 2)
  accumDeprecCurrent Decimal     @default(0) @db.Decimal(18, 2)
  bookValue          Decimal     @default(0) @db.Decimal(18, 2)
  createdAt          DateTime    @default(now())
  deletedAt          DateTime?
  client             Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  importBatch        ImportBatch @relation(fields: [importBatchId], references: [id])

  @@index([clientId, source])
  @@index([importBatchId])
  @@map("fixed_assets")
}

model AccountBalance {
  id          String   @id @default(cuid())
  clientId    String
  accountId   String
  debitTotal  Decimal  @default(0) @db.Decimal(18, 2)
  creditTotal Decimal  @default(0) @db.Decimal(18, 2)
  balance     Decimal  @default(0) @db.Decimal(18, 2)
  updatedAt   DateTime @updatedAt

  @@unique([clientId, accountId])
  @@index([clientId])
  @@map("account_balances")
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  model      String
  recordId   String
  userId     String
  userName   String
  clientId   String?
  before     Json?
  after      Json?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([model, recordId])
  @@index([userId, createdAt])
  @@index([clientId, createdAt])
  @@map("audit_logs")
}

model FinancialReportSnapshot {
  id         String   @id @default(cuid())
  clientId   String
  period     String
  reportType String
  data       Json
  createdAt  DateTime @default(now())
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, period, reportType])
  @@map("financial_report_snapshots")
}

enum Role {
  Admin
  Staff
  Client
}

enum InvoiceStatus {
  Draft
  Terkirim
  Lunas
  JatuhTempo
}

enum TaxDeadlineStatus {
  BelumLapor
  SudahLapor
  Terlambat
}

enum DocumentKategori {
  FakturPajak
  BuktiPotong
  SPT
  LaporanKeuangan
  Lainnya
}

enum PermitCaseStatus {
  Draft
  WaitingDocument
  Verification
  RevisionRequired
  Processing
  Issued
  Completed
  Cancelled
  OnHold
}

enum PermitPriority {
  Low
  Medium
  High
}

enum VerificationStatus {
  Pending
  Approved
  Rejected
}

enum JenisWP {
  OrangPribadi
  Badan
}

enum ClientStatus {
  Aktif
  TidakAktif
}

enum RecurringInterval {
  Monthly
  Quarterly
  Yearly
}

enum AccountType {
  Asset
  Liability
  Equity
  Revenue
  Expense
}

enum JournalStatus {
  Draft
  Posted
}

enum AccDocType {
  SalesInvoice
  PurchaseInvoice
  ExpenseReceipt
  BankStatement
  FinancialReport
  Other
}

enum AccDocModule {
  Receivable
  Payable
  Expense
  Cashflow
  FinancialReport
}
